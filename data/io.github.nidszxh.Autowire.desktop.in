[Desktop Entry]
Name=Autowire
GenericName=Audio Profile Manager
Comment=Automatically route audio when devices connect
Exec=autowire
Icon=@APPLICATION_ID@
Terminal=false
Type=Application
Categories=AudioVideo;Audio;Settings;
Keywords=audio;sound;pipewire;wireplumber;headset;speaker;microphone;routing;profile;
StartupWMClass=@APPLICATION_ID@
X-GNOME-UsesNotifications=false
