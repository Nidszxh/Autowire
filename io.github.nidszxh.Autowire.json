{
  "app-id": "io.github.nidszxh.Autowire",
  "runtime": "org.gnome.Platform",
  "runtime-version": "50",
  "sdk": "org.gnome.Sdk",
  "command": "autowire",
  "finish-args": [
    "--share=ipc",
    "--socket=wayland",
    "--socket=fallback-x11",
    "--socket=pulseaudio",
    "--talk-name=org.freedesktop.WirePlumber",
    "--share=network"
  ],
  "cleanup": [
    "/include",
    "/lib/pkgconfig",
    "/lib/cmake",
    "*.la",
    "*.a"
  ],
  "modules": [
    {
      "name": "autowire-wrapper",
      "buildsystem": "simple",
      "build-commands": [
        "install -d /app/bin",
        "install -m 755 autowire-wrapper.sh /app/bin/autowire",
        "install -m 755 autowire-daemon-wrapper.sh /app/bin/autowire-daemon"
      ],
      "sources": [
        {
          "type": "file",
          "path": "autowire-wrapper.sh"
        },
        {
          "type": "file",
          "path": "autowire-daemon-wrapper.sh"
        }
      ]
    },
    {
      "name": "autowire-sources",
      "buildsystem": "simple",
      "build-commands": [
        "install -d /app/share/autowire",
        "install -m 444 main.js /app/share/autowire/",
        "install -m 444 window.js /app/share/autowire/",
        "install -m 444 profile_dialog.js /app/share/autowire/",
        "install -m 444 config_mgr.js /app/share/autowire/",
        "install -m 444 daemon.js /app/share/autowire/",
        "install -m 444 daemon_main.js /app/share/autowire/",
        "install -m 444 wp_monitor.js /app/share/autowire/"
      ],
      "sources": [
        {
          "type": "dir",
          "path": "src"
        }
      ]
    }
  ]
}
