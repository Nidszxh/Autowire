{
  "app-id": "io.github.nidszxh.Autowire",
  "runtime": "org.gnome.Platform",
  "runtime-version": "48",
  "sdk": "org.gnome.Sdk",
  "command": "autowire",
  "finish-args": [
    "--share=ipc",
    "--socket=wayland",
    "--socket=fallback-x11",
    "--socket=session-bus",
    "--filesystem=xdg-run/pipewire-0",
    "--talk-name=org.freedesktop.WirePlumber",
    "--talk-name=org.freedesktop.portal.Desktop",
    "--system-talk-name=org.freedesktop.login1"
  ],
  "cleanup": [
    "/include",
    "/lib/pkgconfig",
    "/lib/cmake",
    "*.la",
    "*.a"
  ],
  "modules": [
    {
      "name": "blueprint-compiler",
      "buildsystem": "meson",
      "cleanup": ["*"],
      "sources": [
        {
          "type": "git",
          "url": "https://gitlab.gnome.org/jwestman/blueprint-compiler.git",
          "tag": "v0.14.0",
          "commit": "9c5f9d10a0ba1a2e1b76ac5a41e0e9e9d5f38d79",
          "x-checker-data": {
            "type": "git",
            "tag-pattern": "^v([\\d.]+)$"
          }
        }
      ]
    },
    {
      "name": "autowire",
      "buildsystem": "meson",
      "sources": [
        {
          "type": "dir",
          "path": "."
        }
      ]
    }
  ]
}
